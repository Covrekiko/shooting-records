{
  "name": "ReloadingTestVariant",
  "type": "object",
  "properties": {
    "test_id": {
      "type": "string",
      "description": "Parent ReloadingTest ID"
    },
    "label": {
      "type": "string",
      "description": "Variant label e.g. N160 \u2013 40.0gr"
    },
    "round_count": {
      "type": "integer",
      "default": 0
    },
    "powder_name": {
      "type": "string"
    },
    "powder_component_id": {
      "type": "string"
    },
    "powder_charge_grains": {
      "type": "number"
    },
    "powder_lot_number": {
      "type": "string",
      "description": "Powder lot or batch number used for this variant"
    },
    "bullet_brand": {
      "type": "string"
    },
    "bullet_component_id": {
      "type": "string"
    },
    "bullet_quantity_used": {
      "type": "integer"
    },
    "bullet_lot_number": {
      "type": "string",
      "description": "Bullet lot or batch number used for this variant"
    },
    "brass_brand": {
      "type": "string"
    },
    "brass_component_id": {
      "type": "string"
    },
    "brass_quantity_used": {
      "type": "integer"
    },
    "brass_lot_number": {
      "type": "string",
      "description": "Brass lot or batch number used for this variant"
    },
    "primer_brand": {
      "type": "string"
    },
    "primer_component_id": {
      "type": "string"
    },
    "primer_quantity_used": {
      "type": "integer"
    },
    "primer_lot_number": {
      "type": "string",
      "description": "Primer lot or batch number used for this variant"
    },
    "seating_depth": {
      "type": "string"
    },
    "coal_oal": {
      "type": "string",
      "description": "Cartridge Overall Length"
    },
    "cbto": {
      "type": "string",
      "description": "Cartridge Base To Ogive"
    },
    "bullet_jump": {
      "type": "string"
    },
    "neck_tension": {
      "type": "string"
    },
    "crimp": {
      "type": "string"
    },
    "case_trim_length": {
      "type": "string"
    },
    "case_prep_notes": {
      "type": "string"
    },
    "annealed": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string"
    },
    "stock_deducted": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "test_id",
    "label"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "normal_user"
          }
        },
        {
          "user_condition": {
            "role": "beta_tester"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}