{
  "name": "User",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "banned"
      ],
      "default": "active"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "normal_user",
        "beta_tester"
      ],
      "default": "normal_user",
      "description": "User role: admin, normal_user, or beta_tester"
    },
    "firstName": {
      "type": "string",
      "description": "User's first name"
    },
    "middleName": {
      "type": "string",
      "description": "User's middle name (optional)"
    },
    "lastName": {
      "type": "string",
      "description": "User's surname / last name"
    },
    "dateOfBirth": {
      "type": "string",
      "format": "date",
      "description": "User's date of birth"
    },
    "addressLine1": {
      "type": "string",
      "description": "Address line 1"
    },
    "addressLine2": {
      "type": "string",
      "description": "Address line 2 (optional)"
    },
    "city": {
      "type": "string",
      "description": "City or town"
    },
    "postcode": {
      "type": "string",
      "description": "Postcode / ZIP code"
    },
    "country": {
      "type": "string",
      "description": "Country"
    },
    "phone": {
      "type": "string",
      "description": "Phone number (optional)"
    },
    "profileComplete": {
      "type": "boolean",
      "default": false,
      "description": "Whether the user has completed their profile setup"
    },
    "beta_tester_status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "description": "Beta tester status (only for beta_tester role)"
    },
    "beta_tester_notes": {
      "type": "string",
      "description": "Notes about the beta tester"
    },
    "beta_tester_expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the beta tester access expires (optional)"
    }
  },
  "required": []
}